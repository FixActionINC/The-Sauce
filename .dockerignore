# =============================================================================
# Docker Build Context Exclusions
# Reduces build context size and prevents sensitive files from entering the image.
# =============================================================================

# Dependencies -- reinstalled inside the container via pnpm install
node_modules

# Next.js build output -- rebuilt inside the container
.next

# Turbo cache -- not needed in the image
.turbo

# Git history -- not needed in the image
.git
.gitignore

# Local database files
*.db
*.db-journal

# Environment files -- secrets must be passed via env_file or environment vars
.env
.env.local
.env.*.local
.env.production
.env.development

# Docker config -- avoid recursive context inclusion
docker/
!docker/entrypoint.sh

# Documentation -- not needed at runtime
*.md

# Infrastructure-as-code -- not part of the application
terraform/

# CI/CD configuration -- not needed in the image
.github/

# Claude Code project config -- not needed in the image
.claude/
