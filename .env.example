# =============================================================================
# The Sauce - Environment Variables Reference
#
# PRODUCTION: All secrets are managed via AWS SSM Parameter Store.
# deploy.sh pulls from SSM and writes .env on the EC2 instance.
# Do NOT commit real secrets to this file or any .env file.
#
# LOCAL DEV: Copy this to apps/web/.env and fill in your values.
# =============================================================================

# ============================================
# DATABASE (Prisma + PostgreSQL on RDS)
# ============================================
DATABASE_URL="postgresql://user:password@host:5432/thesauce"

# ============================================
# ADMIN
# ============================================
# Session signing secret (generate: openssl rand -base64 32)
# REQUIRED in production - app will refuse to start without it
ADMIN_SECRET=

# ============================================
# SQUARE PAYMENTS
# ============================================
SQUARE_ACCESS_TOKEN=              # From Square Developer Dashboard
SQUARE_ENVIRONMENT=sandbox        # sandbox or production
SQUARE_LOCATION_ID=               # From Square Dashboard > Locations
SQUARE_WEBHOOK_SIGNATURE_KEY=     # From Square Dashboard > Webhooks
SQUARE_WEBHOOK_URL=               # Public URL: https://yourdomain.com/api/webhooks/square

# ============================================
# AWS (S3 image uploads + CloudFront CDN)
# ============================================
AWS_REGION=us-east-1
S3_IMAGES_BUCKET=                 # From terraform output: s3_images_bucket
CLOUDFRONT_DOMAIN=                # From terraform output: cloudfront_domain

# ============================================
# DYNAMODB (Admin sessions)
# ============================================
DYNAMODB_SESSIONS_TABLE=             # From terraform output: dynamodb_table_name

# ============================================
# NEXT.JS
# ============================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ISR Revalidation secret (generate: openssl rand -base64 32)
REVALIDATION_SECRET=

# ============================================
# DOCKER / PRODUCTION
# ============================================
DOMAIN=jonesingforsauce.com
CERTBOT_EMAIL=admin@jonesingforsauce.com
